rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Breakthrough Coaching & Consulting — Firestore Security Rules v2
//
// IMPORTANT: Roles are stored in /users/{uid}.role (Firestore document),
// NOT in Firebase Auth custom claims. This matches the client-side pattern.
//
// Role values: "Admin" | "Coordinator" | "Practice Manager" | "Practitioner" | "Viewer"
//
// Access matrix:
//   users                 → owner read/write their own doc; Admin reads all
//   clients               → clinical staff & managers read; Coordinator+ write
//   abcLogs               → clinical staff read+write; Viewer read
//   bspPlans              → clinical staff read+write; Viewer read
//   ndisPlans             → all staff read; Manager+ write
//   practitioners         → own doc read; Coordinator+ read all; Coordinator+ write
//   incidents             → clinical staff create+read; Coordinator+ update/delete
//   auditLogs             → Admin read only (append-only via Cloud Functions)
//   complianceChecklists  → Manager+ read+write
//   serviceAgreements     → Manager+ read+write
//   billingRecords        → Manager+ read+write
//   claims                → Manager+ read+write (PRODA/NDIS claim approve-reject)
//   calendar_events       → any auth read; Coordinator+ write
//   analytics             → any staff read; client write denied (Cloud Functions only)
//   documents             → read requires 'all' or caller's role in allowedRoles; Coordinator+ write
//   secure_messages       → any staff read+write (shared team channel, not per-DM)
//   legoSessions          → clinical staff read+write; Manager read
//   caseNotes             → clinical staff read+write (Practitioner: own only)
//   knowledgeBase         → any auth read; Coordinator+ write
//   notifications         → owner read; owner update (mark-read); Coordinator+ create
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: is the request from a signed-in user? ─────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    // ── Helper: fetch the caller's role from Firestore ────────────────────────
    // Falls back to "Viewer" if the document doesn't exist yet.
    function userRole() {
      return isAuth()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'Viewer')
        : 'Viewer';
    }

    // ── Role convenience helpers ──────────────────────────────────────────────
    function isAdmin() {
      return userRole() == 'Admin';
    }

    function isCoordinator() {
      return userRole() in ['Admin', 'Coordinator'];
    }

    function isPracticeManager() {
      return userRole() in ['Admin', 'Coordinator', 'Practice Manager'];
    }

    function isClinicalStaff() {
      return userRole() in ['Admin', 'Coordinator', 'Practitioner'];
    }

    function isAnyStaff() {
      return userRole() in ['Admin', 'Coordinator', 'Practice Manager', 'Practitioner'];
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // ── User Profiles ─────────────────────────────────────────────────────────
    // Every authenticated user may read and update their own profile.
    // Admins may read any user profile. Deletion is Admin-only.
    // SECURITY: owners may NOT change their own `role` field — only Admins can.
    // Since userRole() reads this doc live, an unrestricted self-update here
    // would let any signed-in user grant themselves Admin.
    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isAuth() &&
                       request.resource.data.role == 'Viewer';
      allow update: if isAdmin() ||
                       (isOwner(userId) &&
                        request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // ── Clients ───────────────────────────────────────────────────────────────
    match /clients/{clientId} {
      allow read:          if isClinicalStaff() || isPracticeManager();
      allow create, update: if isCoordinator();
      allow delete:        if isAdmin();
    }

    // ── ABC Behaviour Logs ────────────────────────────────────────────────────
    match /abcLogs/{docId} {
      allow read:          if isAnyStaff();
      allow create, update: if isClinicalStaff();
      allow delete:        if isCoordinator();
    }

    // ── Behaviour Support Plans ───────────────────────────────────────────────
    match /bspPlans/{docId} {
      allow read:          if isAnyStaff();
      allow create, update: if isClinicalStaff();
      allow delete:        if isCoordinator();
    }

    // ── NDIS Plans ────────────────────────────────────────────────────────────
    match /ndisPlans/{docId} {
      allow read:          if isAnyStaff();
      allow create, update: if isPracticeManager();
      allow delete:        if isAdmin();
    }

    // ── Practitioners / Staff ─────────────────────────────────────────────────
    match /practitioners/{practitionerId} {
      allow read:          if isOwner(practitionerId) || isPracticeManager();
      allow create, update: if isCoordinator();
      allow delete:        if isAdmin();
    }

    // ── Incidents ─────────────────────────────────────────────────────────────
    match /incidents/{incidentId} {
      allow read:   if isClinicalStaff() || isPracticeManager();
      allow create: if isClinicalStaff();
      allow update: if isCoordinator();
      allow delete: if isAdmin();
    }

    // ── Audit Logs — append-only via Cloud Functions ──────────────────────────
    match /auditLogs/{logId} {
      allow read:  if isAdmin();
      allow write: if false; // Cloud Functions only
    }

    // ── Compliance Checklists ─────────────────────────────────────────────────
    match /complianceChecklists/{docId} {
      allow read, write: if isPracticeManager();
    }

    // ── Service Agreements ────────────────────────────────────────────────────
    match /serviceAgreements/{docId} {
      allow read, write: if isPracticeManager();
    }

    // ── Billing Records ───────────────────────────────────────────────────────
    match /billingRecords/{docId} {
      allow read, write: if isPracticeManager();
    }

    // ── PRODA / NDIS Claims ───────────────────────────────────────────────────
    // Was previously unmatched by any rule and silently falling through to the
    // default-deny at the bottom of this file — approve/reject would have
    // failed with a permissions error against a real Firestore backend.
    match /claims/{claimId} {
      allow read, write: if isPracticeManager();
    }

    // ── LEGO® Therapy Sessions ────────────────────────────────────────────────
    match /legoSessions/{sessionId} {
      allow read:          if isAnyStaff();
      allow create, update: if isClinicalStaff();
      allow delete:        if isCoordinator();
    }

    // ── Case Notes ────────────────────────────────────────────────────────────
    match /caseNotes/{noteId} {
      allow read:   if isClinicalStaff() || isPracticeManager();
      allow create: if isClinicalStaff();
      allow update: if isCoordinator() ||
                       (isAuth() && userRole() == 'Practitioner' &&
                        resource.data.authorUid == request.auth.uid &&
                        request.resource.data.authorUid == resource.data.authorUid);
      allow delete: if isCoordinator();
    }

    // ── Knowledge Base Documents ──────────────────────────────────────────────
    match /knowledgeBase/{docId} {
      allow read:  if isAuth();
      allow write: if isCoordinator();
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    // Owners may only toggle their own notification's `read` flag — not
    // rewrite its content (title, body, userId, etc).
    match /notifications/{notifId} {
      allow read:   if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isCoordinator();
      allow update: if isAuth() && resource.data.userId == request.auth.uid &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }

    // ── Calendar Events ────────────────────────────────────────────────────────
    // Was previously unmatched by any rule, same silent-fallthrough issue as
    // claims — the calendar UI would have failed with a permissions error
    // against the real backend.
    match /calendar_events/{eventId} {
      allow read:           if isAuth();
      allow create, update: if isCoordinator();
      allow delete:         if isCoordinator();
    }

    // ── Analytics (dashboard metrics) ───────────────────────────────────────────
    // Written exclusively by the aggregateDashboardMetricsScheduled /
    // refreshDashboardMetrics Cloud Functions via the Admin SDK, which bypasses
    // these rules entirely — so `allow write: if false` here blocks direct
    // client writes without blocking the functions that actually populate it.
    // This mirrors the auditLogs pattern (Admin-SDK-only writes), but readable
    // by any staff member since dashboard KPIs aren't as sensitive as raw
    // audit trail entries.
    match /analytics/{docId} {
      allow read:  if isAnyStaff();
      allow write: if false;
    }

    // ── Documents (shared document library / RAG source material) ─────────────
    // Was previously unmatched — DocumentLibrary and the RAG knowledge features
    // would have failed with permissions errors against a real backend.
    // Read access follows the document's own allowedRoles field: 'all' means
    // any authenticated staff member, otherwise the caller's role must appear
    // in that list. Uploads/deletes are Coordinator+ only.
    match /documents/{docId} {
      allow read:   if isAnyStaff() &&
                       ('all' in resource.data.allowedRoles || userRole() in resource.data.allowedRoles);
      allow create: if isCoordinator();
      allow update, delete: if isCoordinator();
    }

    // ── Secure Messages ─────────────────────────────────────────────────────────
    // Was previously unmatched — SecureMessaging would have failed with
    // permissions errors against a real backend. MessageRepository.ts reads
    // the whole collection with no per-conversation filter, i.e. this is
    // implemented as one shared team channel, not per-user DMs — the rule
    // matches that: any staff member can read and post.
    match /secure_messages/{messageId} {
      allow read, create: if isAnyStaff();
      allow update, delete: if isAdmin();
    }

    // ── Default: deny everything not explicitly matched ───────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
